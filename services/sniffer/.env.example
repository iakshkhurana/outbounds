# Use 127.0.0.1 (not localhost) on Windows — localhost can hit a different process than Docker.
OUTBOUNDS_API_URL=http://127.0.0.1:4000/api/events
OUTBOUNDS_HEARTBEAT_URL=http://127.0.0.1:4000/api/heartbeat
OUTBOUNDS_TOKEN=dev-local-token
BATCH_MS=1000
# connections = real OS sockets (Chrome traffic) — default, no Npcap
# live        = Scapy/Npcap packet capture
# dry-run     = fake demo events
MODE=connections
# CAPTURE_IFACE=
